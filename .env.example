# Nepali News API Configuration
# Copy this file to .env and fill in your API keys

# NewsData.io API Key (supports Nepali language)
# Get free API key at: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Google Fact Check Tools API (https://developers.google.com/fact-check/tools/api)
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key_here
# Or reuse the same key as other Google APIs:
# GOOGLE_API_KEY=your_google_api_key_here
